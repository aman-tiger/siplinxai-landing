---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
const isRuPage = Astro.url.pathname.startsWith('/ru');
const lang = isRuPage ? 'ru' : language;
---

<!doctype html>
<html lang={lang} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />

    <!-- Global UI animation styles -->
    <style>
      /* Scroll-reveal helpers for custom pages */
      .reveal {
        opacity: 0;
        transform: translateY(1.5rem);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .reveal.revealed {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-left {
        opacity: 0;
        transform: translateX(-2rem);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .reveal-left.revealed {
        opacity: 1;
        transform: translateX(0);
      }
      .reveal-scale {
        opacity: 0;
        transform: scale(0.93);
        transition: opacity 0.5s ease, transform 0.5s ease;
      }
      .reveal-scale.revealed {
        opacity: 1;
        transform: scale(1);
      }
      /* Gradient animated border glow on hover for cards */
      .card-hover {
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      }
      .card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 40px -8px rgba(59, 130, 246, 0.2);
      }
      /* Animated gradient text */
      .gradient-animate {
        background-size: 200% auto;
        animation: gradientShift 4s ease infinite;
        background-image: linear-gradient(90deg, #3b82f6, #7c3aed, #3b82f6);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      /* Floating orbs in hero backgrounds */
      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.35;
        animation: floatUp 6s ease-in-out infinite;
        pointer-events: none;
      }
      .orb-blue { background: #3b82f6; animation-delay: 0s; }
      .orb-violet { background: #7c3aed; animation-delay: -3s; }
      .orb-cyan { background: #06b6d4; animation-delay: -1.5s; }
      /* Shimmer CTA button effect */
      .btn-shimmer {
        position: relative;
        overflow: hidden;
      }
      .btn-shimmer::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.25) 50%, transparent 60%);
        background-size: 200% 100%;
        animation: shimmer 2.5s ease infinite;
      }
    </style>

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xbp2gn6ew9");
    </script>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />

    <!-- Scroll reveal for custom pages -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>('.reveal, .reveal-left, .reveal-scale');
        if (!els.length) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry, idx) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = (el.dataset.delay ? parseInt(el.dataset.delay) : idx * 80);
              setTimeout(() => el.classList.add('revealed'), delay);
              io.unobserve(el);
            }
          });
        }, { threshold: 0.1 });
        els.forEach(el => io.observe(el));
      }
      initReveal();
      document.addEventListener('astro:after-swap', initReveal);
    </script>

    <!-- Clarity event tracking -->
    <script>
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest('a, button');
        if (!target) return;
        const href = (target as HTMLAnchorElement).href || '';
        const text = target.textContent?.trim().toLowerCase() || '';
        const cls = target.className || '';

        const fire = (event: string) => {
          if (typeof (window as any).clarity === 'function') {
            (window as any).clarity('event', event);
          }
        };

        if (href.includes('/download') || text.includes('download') || text.includes('скачать')) {
          if (cls.includes('hero-btn') || cls.includes('hero')) fire('click_download_hero');
          else if (cls.includes('cta-btn') || cls.includes('cta')) fire('click_download_cta');
          else fire('click_download_nav');
        } else if (href.includes('/pricing') || text.includes('pricing') || text.includes('цены') || text.includes('тарифы')) {
          fire('click_pricing_nav');
        } else if (href.includes('/help') || text.includes('help center') || text.includes('центр помощи')) {
          fire('click_help_center');
        } else if (href.includes('/blog') || text.includes('blog') || text.includes('блог')) {
          fire('click_blog');
        } else if (text.includes('get started') || text.includes('buy') || text.includes('choose') || text.includes('начать')) {
          if (text.includes('starter') || text.includes('monthly') || text.includes('месяц')) fire('click_pricing_starter');
          else if (text.includes('pro') || text.includes('annual') || text.includes('год')) fire('click_pricing_pro');
          else fire('click_pricing_cta');
        }
      });
    </script>

    <script>
      (function () {
        const stored = localStorage.getItem('siplinx-lang');
        const path = window.location.pathname;
        const onRu = path.startsWith('/ru');
        if (!stored) {
          const bl = (navigator.language || '').toLowerCase();
          const wantRu = bl.startsWith('ru');
          localStorage.setItem('siplinx-lang', wantRu ? 'ru' : 'en');
          if (wantRu && !onRu) {
            window.location.replace('/ru' + (path === '/' ? '' : path));
          }
        } else if (stored === 'ru' && !onRu) {
          window.location.replace('/ru' + (path === '/' ? '' : path));
        } else if (stored === 'en' && onRu) {
          window.location.replace(path.replace(/^\/ru/, '') || '/');
        }
      })();
    </script>
  </body>
</html>
