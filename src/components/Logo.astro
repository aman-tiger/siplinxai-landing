---
import { SITE } from 'astrowind:config';
---

<span class="flex items-center gap-2.5">
  <!-- SipLinxAI "S" ribbon logo — blue→purple gradient with 3D depth -->
  <svg width="36" height="40" viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id="s-grad-top" x1="20" y1="10" x2="180" y2="100" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#93C5FD"/>
        <stop offset="50%" stop-color="#3B82F6"/>
        <stop offset="100%" stop-color="#2563EB"/>
      </linearGradient>
      <linearGradient id="s-grad-bot" x1="20" y1="120" x2="180" y2="215" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#7C3AED"/>
        <stop offset="100%" stop-color="#5B21B6"/>
      </linearGradient>
      <linearGradient id="s-shine-top" x1="30" y1="15" x2="140" y2="80" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#BFDBFE" stop-opacity="0.7"/>
        <stop offset="100%" stop-color="#60A5FA" stop-opacity="0"/>
      </linearGradient>
      <filter id="s-glow">
        <feGaussianBlur stdDeviation="6" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>

    <!-- Bottom arc (rendered first / behind) -->
    <path
      d="M48 178 C48 200 65 213 93 213 L128 213 C157 213 172 199 172 178 C172 159 161 146 138 138 L76 119 C50 110 38 97 38 75 C38 50 55 36 85 36 L120 36 C150 36 164 50 164 72"
      stroke="url(#s-grad-bot)"
      stroke-width="40"
      stroke-linecap="round"
      fill="none"
    />
    <!-- Top arc (rendered on top) -->
    <path
      d="M152 42 C152 20 136 7 108 7 L68 7 C40 7 26 21 26 42 C26 61 37 74 60 82 L122 101 C150 111 163 124 163 145"
      stroke="url(#s-grad-top)"
      stroke-width="40"
      stroke-linecap="round"
      fill="none"
    />
    <!-- Highlight shine on top arc -->
    <path
      d="M152 42 C152 20 136 7 108 7 L68 7 C40 7 26 21 26 42 C26 55 34 66 52 75"
      stroke="url(#s-shine-top)"
      stroke-width="16"
      stroke-linecap="round"
      fill="none"
    />
  </svg>

  <span class="self-center text-xl font-bold whitespace-nowrap tracking-tight text-gray-900 dark:text-white">
    Siplinx <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent">AI</span>
  </span>
</span>
