---

---

<span class="flex items-center gap-2.5">
  <svg
    width="36"
    height="44"
    viewBox="0 0 200 222"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    style="overflow: visible;"
  >
    <defs>
      <!-- Violet gradient for bottom ribbon (renders behind) -->
      <linearGradient id="sl-v" x1="50" y1="106" x2="158" y2="214" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#4338CA"></stop>
        <stop offset="55%" stop-color="#7C3AED"></stop>
        <stop offset="100%" stop-color="#5B21B6"></stop>
      </linearGradient>
      <!-- Cyan→blue gradient for top ribbon (renders in front) -->
      <linearGradient id="sl-b" x1="44" y1="12" x2="152" y2="120" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#BAE6FD"></stop>
        <stop offset="22%" stop-color="#38BDF8"></stop>
        <stop offset="62%" stop-color="#3B82F6"></stop>
        <stop offset="100%" stop-color="#1D4ED8"></stop>
      </linearGradient>
      <!-- White rim highlight on the top ribbon -->
      <linearGradient id="sl-rim" x1="44" y1="12" x2="88" y2="76" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.92"></stop>
        <stop offset="55%" stop-color="#FFFFFF" stop-opacity="0.35"></stop>
        <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"></stop>
      </linearGradient>
      <!-- Soft glow for the crossover seam -->
      <filter id="sl-glow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="7" result="b"></feGaussianBlur>
        <feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
      </filter>
    </defs>

    <!-- ── Bottom half / violet ribbon (back layer) ─────────────── -->
    <path
      d="M52 168 C50 194 68 214 96 214 L118 214 C146 214 158 196 158 172 C158 150 145 135 120 126 L78 110"
      stroke="url(#sl-v)"
      stroke-width="40"
      stroke-linecap="round"
      fill="none"></path>

    <!-- ── Top half / blue ribbon (front layer — covers crossover) ─ -->
    <path
      d="M148 52 C148 27 131 10 106 10 L83 10 C55 10 44 28 44 54 C44 78 57 94 83 104 L124 120"
      stroke="url(#sl-b)"
      stroke-width="40"
      stroke-linecap="round"
      fill="none"></path>

    <!-- ── Outer-edge rim light (the lit upper edge of blue ribbon) ─ -->
    <path
      d="M148 52 C148 27 131 10 106 10 L83 10 C55 10 44 28 44 54 C44 69 52 82 66 91"
      stroke="url(#sl-rim)"
      stroke-width="11"
      stroke-linecap="round"
      fill="none"></path>

    <!-- ── Bright seam glow at the crossover point ───────────────── -->
    <ellipse
      cx="101"
      cy="115"
      rx="5"
      ry="10"
      fill="white"
      opacity="0.75"
      transform="rotate(-28 101 115)"
      filter="url(#sl-glow)"></ellipse>
    <ellipse cx="101" cy="115" rx="2.5" ry="5" fill="white" opacity="1" transform="rotate(-28 101 115)"></ellipse>
  </svg>

  <span class="self-center text-xl font-bold whitespace-nowrap tracking-tight text-gray-900 dark:text-white">
    Siplinx <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent">AI</span>
  </span>
</span>
