---
import { SITE } from 'astrowind:config';
---

<span class="flex items-center gap-2.5">
  <!-- Siplinx AI — 3D ribbon S logo, blue→purple gradient -->
  <svg
    width="36"
    height="44"
    viewBox="0 0 180 220"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    style="overflow: visible;"
  >
    <defs>
      <linearGradient id="lg-top" x1="20" y1="20" x2="160" y2="100" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#93C5FD"/>
        <stop offset="60%" stop-color="#3B82F6"/>
        <stop offset="100%" stop-color="#2563EB"/>
      </linearGradient>
      <linearGradient id="lg-bot" x1="20" y1="110" x2="160" y2="200" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#8B5CF6"/>
        <stop offset="100%" stop-color="#6D28D9"/>
      </linearGradient>
      <linearGradient id="lg-shine" x1="30" y1="20" x2="120" y2="70" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#DBEAFE" stop-opacity="0.8"/>
        <stop offset="100%" stop-color="#93C5FD" stop-opacity="0"/>
      </linearGradient>
    </defs>

    <!-- Bottom arc of S (behind) -->
    <path
      d="M50 170 C50 188 64 198 85 198 L112 198 C134 198 146 186 146 168 C146 152 137 142 118 136 L72 120 C50 112 40 100 40 82 C40 62 54 52 76 52 L104 52 C126 52 138 62 138 80"
      stroke="url(#lg-bot)"
      stroke-width="34"
      stroke-linecap="round"
      fill="none"
    />
    <!-- Top arc of S (in front) -->
    <path
      d="M130 50 C130 32 116 22 95 22 L68 22 C46 22 34 34 34 52 C34 68 43 78 62 84 L108 100 C130 108 142 120 142 140"
      stroke="url(#lg-top)"
      stroke-width="34"
      stroke-linecap="round"
      fill="none"
    />
    <!-- Shine highlight on top arc -->
    <path
      d="M130 50 C130 32 116 22 95 22 L68 22 C46 22 34 34 34 52 C34 64 41 72 56 78"
      stroke="url(#lg-shine)"
      stroke-width="13"
      stroke-linecap="round"
      fill="none"
    />
  </svg>

  <span class="self-center text-xl font-bold whitespace-nowrap tracking-tight text-gray-900 dark:text-white">
    Siplinx <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent">AI</span>
  </span>
</span>
