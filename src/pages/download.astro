---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Download SipLinxAI',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Free Download"
    title="Download SipLinxAI"
    subtitle="Available for Mac and Windows. Free to start — no account, no credit card required."
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Download Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <!-- Mac -->
      <div class="relative rounded-2xl border border-gray-200 dark:border-blue-900 bg-gradient-to-br from-gray-50 via-blue-50/30 to-violet-50/40 dark:from-[#0A0918] dark:via-blue-950/30 dark:to-violet-950/30 p-8 text-center shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-gray-800 to-black mb-6 shadow-lg">
          <Icon name="tabler:brand-apple" class="w-10 h-10 text-white" />
        </div>
        <h2 class="text-2xl font-bold mb-2 dark:text-white">Download for Mac</h2>
        <p class="text-muted dark:text-slate-400 mb-1">macOS 12 (Monterey) or later</p>
        <p class="text-sm text-muted dark:text-slate-500 mb-6">Apple Silicon &amp; Intel · ~85 MB</p>
        <a
          href="#"
          class="inline-flex items-center gap-2 w-full justify-center px-6 py-4 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white font-bold rounded-xl transition-all duration-200 shadow-md hover:shadow-lg text-base"
        >
          <Icon name="tabler:download" class="w-5 h-5" />
          Download .dmg
        </a>
        <p class="text-xs text-muted dark:text-slate-500 mt-3">Free · Version 1.0.0</p>
      </div>

      <!-- Windows -->
      <div class="relative rounded-2xl border border-gray-200 dark:border-blue-900 bg-gradient-to-br from-gray-50 via-blue-50/30 to-cyan-50/40 dark:from-[#0A0918] dark:via-blue-950/30 dark:to-cyan-950/30 p-8 text-center shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 mb-6 shadow-lg">
          <Icon name="tabler:brand-windows" class="w-10 h-10 text-white" />
        </div>
        <h2 class="text-2xl font-bold mb-2 dark:text-white">Download for Windows</h2>
        <p class="text-muted dark:text-slate-400 mb-1">Windows 10 / 11 (64-bit)</p>
        <p class="text-sm text-muted dark:text-slate-500 mb-6">x64 · ~92 MB</p>
        <a
          href="#"
          class="inline-flex items-center gap-2 w-full justify-center px-6 py-4 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white font-bold rounded-xl transition-all duration-200 shadow-md hover:shadow-lg text-base"
        >
          <Icon name="tabler:download" class="w-5 h-5" />
          Download .exe
        </a>
        <p class="text-xs text-muted dark:text-slate-500 mt-3">Free · Version 1.0.0</p>
      </div>
    </div>

    <!-- Feature highlights -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 mb-4">
          <Icon name="tabler:shield-lock" class="w-6 h-6 text-white" />
        </div>
        <h3 class="font-bold mb-2 dark:text-white">100% Private</h3>
        <p class="text-sm text-muted dark:text-slate-400">All processing happens on your device. Nothing leaves your machine.</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 mb-4">
          <Icon name="tabler:rocket" class="w-6 h-6 text-white" />
        </div>
        <h3 class="font-bold mb-2 dark:text-white">Instant Setup</h3>
        <p class="text-sm text-muted dark:text-slate-400">Install and start transcribing in under 2 minutes. No account needed.</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 mb-4">
          <Icon name="tabler:refresh" class="w-6 h-6 text-white" />
        </div>
        <h3 class="font-bold mb-2 dark:text-white">Free Updates</h3>
        <p class="text-sm text-muted dark:text-slate-400">Automatic updates with new features and model improvements.</p>
      </div>
    </div>

    <!-- Pricing note -->
    <div class="text-center p-8 rounded-2xl border border-blue-200 dark:border-blue-900 bg-gradient-to-br from-blue-50 to-violet-50 dark:from-blue-950/30 dark:to-violet-950/30">
      <h3 class="text-xl font-bold mb-2 dark:text-white">Free Plan Included</h3>
      <p class="text-muted dark:text-slate-400 mb-4">Start free. Upgrade anytime for unlimited access.</p>
      <a href="/pricing" class="inline-flex items-center gap-1 bg-gradient-to-r from-blue-600 to-violet-600 bg-clip-text text-transparent font-semibold hover:underline">
        View Pricing →
      </a>
    </div>
  </div>
</Layout>
