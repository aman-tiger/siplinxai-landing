---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'SipLinxAI — AI Meeting Notes That Stay Private',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget -->
  <Hero
    tagline="Now available for Mac & Windows"
    actions={[
      {
        variant: 'primary',
        text: 'Download for Mac',
        href: '/download',
        icon: 'tabler:brand-apple',
      },
      {
        text: 'Download for Windows',
        href: '/download',
        icon: 'tabler:brand-windows',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'SipLinxAI meeting notes dashboard',
    }}
  >
    <Fragment slot="title">
      Your AI meeting companion<br />
      <span class="text-accent dark:text-violet-400">that never leaves your device</span>
    </Fragment>

    <Fragment slot="subtitle">
      SipLinxAI listens, transcribes, and writes your meeting notes in real time —
      all processed <strong>locally on your machine</strong>. No cloud. No data leaks. Just perfect notes.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-50 via-white to-indigo-50 dark:from-[#0D0A1E] dark:via-[#07050F] dark:to-[#0A0D1E]"></div>
    </Fragment>
  </Hero>

  <!-- Note Widget -->
  <Note
    title="Works with:"
    description="Zoom · Google Meet · Microsoft Teams · Webex · Slack Huddles · In-person meetings"
  />

  <!-- Features Widget -->
  <Features
    id="features"
    tagline="Why SipLinxAI"
    title="Everything your meetings deserve"
    subtitle="Powerful AI features that respect your privacy. Your conversations never leave your device."
    items={[
      {
        title: 'Real-time AI Transcription',
        description:
          'Accurate, speaker-labeled transcripts generated instantly as you speak — powered by on-device AI models with no latency.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Smart Summaries',
        description:
          'Get concise meeting summaries automatically. Key decisions, discussion points, and context — all captured and organized.',
        icon: 'tabler:file-text-ai',
      },
      {
        title: 'Action Items Extraction',
        description:
          'SipLinxAI identifies tasks and commitments automatically. Never forget a follow-up, deadline, or decision again.',
        icon: 'tabler:list-check',
      },
      {
        title: '100% Private & Local',
        description:
          'Your meetings are confidential. Everything runs on your device. No cloud processing, no data storage on our servers, ever.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Multi-Platform Support',
        description:
          'Works seamlessly with Zoom, Google Meet, Microsoft Teams, Webex, and any audio source on your Mac or Windows PC.',
        icon: 'tabler:apps',
      },
      {
        title: 'Instant Search & Export',
        description:
          'Search across all your meeting notes instantly. Export to Notion, Markdown, PDF, or your favorite productivity tool.',
        icon: 'tabler:search',
      },
    ]}
  />

  <!-- Steps Widget (How it Works) -->
  <Steps
    id="how-it-works"
    title="Get perfect meeting notes in 3 simple steps"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Download & Install</span>',
        description:
          'Download SipLinxAI for Mac or Windows. Installation takes under 2 minutes. No account required — just install and launch.',
        icon: 'tabler:download',
      },
      {
        title: 'Step 2: <span class="font-medium">Join Your Meeting</span>',
        description:
          'Start any meeting on Zoom, Google Meet, Teams, or any platform. SipLinxAI automatically detects audio and begins transcribing.',
        icon: 'tabler:video',
      },
      {
        title: 'Step 3: <span class="font-medium">Get Your Notes</span>',
        description:
          'When the meeting ends, your notes are ready: full transcript, smart summary, action items, and key decisions — all organized.',
        icon: 'tabler:notes',
      },
      {
        title: 'Done! Focus on the conversation.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'SipLinxAI in action',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-violet-50 to-white dark:from-[#0D0A1E] dark:to-transparent"></div>
    </Fragment>
  </Steps>

  <!-- Stats Widget -->
  <Stats
    stats={[
      { title: 'Meetings Transcribed', amount: '2.4M+' },
      { title: 'Active Users', amount: '48K+' },
      { title: 'Transcription Accuracy', amount: '98.5%' },
      { title: 'Hours Saved Weekly', amount: '4 hrs' },
    ]}
  />

  <!-- Testimonials Widget -->
  <Testimonials
    title="Loved by teams who value privacy"
    subtitle="Join thousands of professionals who've upgraded their meeting workflow with SipLinxAI."
    testimonials={[
      {
        testimonial:
          'SipLinxAI changed how our team runs meetings. The summaries are spot-on and the fact that nothing goes to the cloud is a huge deal for our legal team.',
        name: 'Sarah Chen',
        job: 'Head of Operations, TechCorp',
        image: { src: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop', alt: 'Sarah Chen' },
      },
      {
        testimonial:
          'I stopped taking notes in meetings entirely. SipLinxAI handles everything — and the action item extraction saves me at least an hour every day.',
        name: 'Marcus Rodriguez',
        job: 'Product Manager, Startupify',
        image: { src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop', alt: 'Marcus Rodriguez' },
      },
      {
        testimonial:
          'As a consultant working with multiple clients, I needed something private. SipLinxAI is the only tool I trust — local processing is a game-changer.',
        name: 'Priya Patel',
        job: 'Independent Consultant',
        image: { src: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=200&h=200&fit=crop', alt: 'Priya Patel' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-violet-50 to-transparent dark:from-transparent dark:via-[#0D0A1E]/50 dark:to-transparent"></div>
    </Fragment>
  </Testimonials>

  <!-- FAQs Widget -->
  <FAQs
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about SipLinxAI."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does SipLinxAI protect my privacy?',
        description:
          'SipLinxAI runs entirely on your device. All AI processing, transcription, and note generation happens locally — nothing is sent to our servers or any cloud service. Your meeting content stays on your machine.',
      },
      {
        title: 'Which meeting platforms does SipLinxAI support?',
        description:
          'SipLinxAI works with any application that uses your microphone or speaker output — including Zoom, Google Meet, Microsoft Teams, Webex, Slack Huddles, BlueJeans, and in-person meetings.',
      },
      {
        title: 'What are the system requirements?',
        description:
          'For Mac: macOS 12 (Monterey) or later, Apple Silicon or Intel processor, 8GB RAM minimum. For Windows: Windows 10/11 (64-bit), 8GB RAM minimum, 4GB free storage.',
      },
      {
        title: 'Is SipLinxAI free to use?',
        description:
          'SipLinxAI offers a free plan with 10 meetings/month, unlimited for paid plans. Download and try it free — no credit card required.',
      },
      {
        title: 'How accurate is the transcription?',
        description:
          'SipLinxAI achieves 98.5%+ accuracy for clear audio in English. We support 30+ languages and continue improving our on-device models with every release.',
      },
      {
        title: 'Can I export my meeting notes?',
        description:
          'Yes! Export to Markdown, PDF, Notion, Obsidian, Microsoft Word, or copy directly to clipboard. We also offer integrations with popular project management tools.',
      },
    ]}
  />

  <!-- CallToAction Widget -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Download for Mac',
        href: '/download',
        icon: 'tabler:brand-apple',
      },
      {
        variant: 'secondary',
        text: 'Download for Windows',
        href: '/download',
        icon: 'tabler:brand-windows',
      },
    ]}
  >
    <Fragment slot="title">
      Start your first<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> AI-powered meeting today</span>
    </Fragment>

    <Fragment slot="subtitle">
      Free to start. No credit card. No cloud. <br class="hidden md:inline" />
      Your meetings stay yours — always.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-600 to-indigo-700 dark:from-violet-900 dark:to-indigo-950"></div>
    </Fragment>
  </CallToAction>
</Layout>
