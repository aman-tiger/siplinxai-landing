---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'Siplinx AI — AI Meeting Notes That Stay Private',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Promo code banner — top of page -->
  <div class="bg-gradient-to-r from-blue-600 to-violet-600 text-white py-3 px-4 text-center text-sm font-medium">
    🎁 Try it free for 14 days — use promo code
    <span
      class="inline-flex items-center gap-1 mx-1 px-2.5 py-0.5 rounded-md bg-white/20 font-mono font-bold tracking-wider text-white border border-white/30"
    >
      QATEST100
    </span>
    for 100% off your first 14 days
  </div>

  <!-- Hero Widget -->
  <Hero
    tagline="14 days free — no credit card required"
    actions={[
      {
        variant: 'primary',
        text: 'Download for Mac',
        href: 'https://siplinx-ai.vercel.app/download',
        icon: 'tabler:brand-apple',
        class: 'hero-btn-mac',
      },
      {
        variant: 'secondary',
        text: 'Download for Windows',
        href: 'https://siplinx-ai.vercel.app/download',
        icon: 'tabler:brand-windows',
        class: 'hero-btn-win',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?auto=format&fit=crop&w=2070&q=80',
      alt: 'Siplinx AI meeting notes dashboard',
    }}
  >
    <Fragment slot="title">
      Your AI meeting companion<br />
      <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent"
        >that never leaves your device</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Siplinx AI installs local LLM and STT models directly on your machine — then listens, transcribes, and writes your
      meeting notes in real time.
      <strong>No cloud. No data leaks. 100% private.</strong>
    </Fragment>

    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
      >
      </div>
    </Fragment>
  </Hero>

  <!-- Note Widget -->
  <Note
    title="Works with:"
    description="Zoom · Google Meet · Microsoft Teams · Webex · Slack Huddles · In-person meetings"
  />

  <!-- Features Widget -->
  <Features
    id="features"
    tagline="Why Siplinx AI"
    title="Everything your meetings deserve"
    subtitle="Local LLM and STT models run directly on your device — no internet needed, no cloud involved."
    items={[
      {
        title: 'Real-time AI Transcription (STT)',
        description:
          'A local speech-to-text model runs on your machine and converts speech to text in real time — with zero latency and no upload.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Smart Summaries (Local LLM)',
        description:
          'An on-device language model reads your transcript and writes a concise summary with key decisions and context — all locally.',
        icon: 'tabler:file-text-ai',
      },
      {
        title: 'Action Items Extraction',
        description:
          'Siplinx AI identifies tasks and commitments automatically. Never forget a follow-up, deadline, or decision again.',
        icon: 'tabler:list-check',
      },
      {
        title: '100% Private & Local',
        description:
          'LLM and STT models are installed locally on your machine. Your meetings never leave your device. Not even for AI processing.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Multi-Platform Support',
        description:
          'Works with Zoom, Google Meet, Microsoft Teams, Webex, and any audio source on your Mac or Windows PC.',
        icon: 'tabler:apps',
      },
      {
        title: 'Instant Search & Export',
        description:
          'Search across all your meeting notes instantly. Export to Notion, Markdown, PDF, or your favorite productivity tool.',
        icon: 'tabler:search',
      },
    ]}
  />

  <!-- Steps Widget (How it Works) -->
  <Steps
    id="how-it-works"
    title="Get perfect meeting notes in 3 simple steps"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Download & Install</span>',
        description:
          'Download Siplinx AI for Mac or Windows. The installer sets up the local LLM and STT models on your machine — takes under 5 minutes.',
        icon: 'tabler:download',
      },
      {
        title: 'Step 2: <span class="font-medium">Join Your Meeting</span>',
        description:
          'Start any meeting on Zoom, Google Meet, Teams, or any platform. Siplinx AI automatically detects audio and begins transcribing locally.',
        icon: 'tabler:video',
      },
      {
        title: 'Step 3: <span class="font-medium">Get Your Notes</span>',
        description:
          'When the meeting ends, your notes are ready: full transcript, smart summary, action items, and key decisions — all generated on your device.',
        icon: 'tabler:notes',
      },
      {
        title: 'Done! Focus on the conversation.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=2070&q=80',
      alt: 'Siplinx AI in action',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-50 to-white dark:from-[#06051A] dark:to-transparent">
      </div>
    </Fragment>
  </Steps>

  <!-- Testimonials Widget -->
  <Testimonials
    title="Loved by teams who value privacy"
    subtitle="Join professionals who've upgraded their meeting workflow with Siplinx AI."
    testimonials={[
      {
        testimonial:
          'Siplinx AI changed how our team runs meetings. The summaries are spot-on and the fact that nothing goes to the cloud is a huge deal for our legal team.',
        name: 'Sarah Chen',
        job: 'Head of Operations, TechCorp',
        image: {
          src: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop',
          alt: 'Sarah Chen',
        },
      },
      {
        testimonial:
          'I stopped taking notes in meetings entirely. Siplinx AI handles everything — and the action item extraction saves me at least an hour every day.',
        name: 'Marcus Rodriguez',
        job: 'Product Manager, Startupify',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop',
          alt: 'Marcus Rodriguez',
        },
      },
      {
        testimonial:
          'As a consultant working with multiple clients, I needed something private. Siplinx AI is the only tool I trust — local processing is a game-changer.',
        name: 'Priya Patel',
        job: 'Independent Consultant',
        image: {
          src: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=200&h=200&fit=crop',
          alt: 'Priya Patel',
        },
      },
    ]}
  >
    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50 to-transparent dark:from-transparent dark:via-[#06051A]/50 dark:to-transparent"
      >
      </div>
    </Fragment>
  </Testimonials>

  <!-- FAQs Widget -->
  <FAQs
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about Siplinx AI."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does Siplinx AI protect my privacy?',
        description:
          'Siplinx AI installs local LLM and STT models directly on your machine. All transcription and summarization happens on your device — nothing is sent to the internet. Your meeting content never leaves your computer.',
      },
      {
        title: 'How does the 14-day free trial work?',
        description:
          'Download and install Siplinx AI — no credit card needed. Use promo code QATEST100 at checkout for 100% off your first 14 days. After 14 days, choose a paid plan to continue or your subscription ends.',
      },
      {
        title: 'Which meeting platforms does Siplinx AI support?',
        description:
          'Siplinx AI works with any application that uses your microphone or speaker output — including Zoom, Google Meet, Microsoft Teams, Webex, Slack Huddles, and in-person meetings.',
      },
      {
        title: 'What are the system requirements?',
        description:
          'For Mac: macOS 12 (Monterey) or later, Apple Silicon or Intel, 8GB RAM minimum. For Windows: Windows 10/11 (64-bit), 8GB RAM minimum, 4GB free storage for local models.',
      },
      {
        title: 'Do the local AI models need internet to work?',
        description:
          'No. Once the local LLM and STT models are installed during setup, Siplinx AI works completely offline. Internet is only used for optional features like software updates.',
      },
      {
        title: 'Can I export my meeting notes?',
        description:
          'Yes! Export to Markdown, PDF, Notion, Obsidian, Microsoft Word, or copy to clipboard. All exports happen locally — your data never touches our servers.',
      },
    ]}
  />

  <!-- CallToAction Widget -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Download for Mac',
        href: 'https://siplinx-ai.vercel.app/download',
        icon: 'tabler:brand-apple',
        class: 'cta-btn-mac',
      },
      {
        variant: 'secondary',
        text: 'Download for Windows',
        href: 'https://siplinx-ai.vercel.app/download',
        icon: 'tabler:brand-windows',
        class: 'cta-btn-win',
      },
    ]}
  >
    <Fragment slot="title"> Try Siplinx AI free for 14 days </Fragment>

    <Fragment slot="subtitle">
      Use code <span class="font-mono font-bold bg-white/20 px-2 py-0.5 rounded">QATEST100</span> for 100% off. <br
        class="hidden md:inline"
      />
      No credit card. No cloud. Your meetings stay private — always.
    </Fragment>

    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-gradient-to-br from-blue-600 via-blue-700 to-violet-700 dark:from-blue-900 dark:via-blue-950 dark:to-violet-950"
      >
      </div>
    </Fragment>
  </CallToAction>

  <script>
    function detectOS(): 'mac' | 'windows' {
      const uaData = (navigator as any).userAgentData;
      if (uaData?.platform) {
        const p = uaData.platform.toLowerCase();
        if (p.includes('win')) return 'windows';
      }
      const ua = navigator.userAgent.toLowerCase();
      const platform = (navigator.platform || '').toLowerCase();
      if (platform.includes('win') || ua.includes('windows nt') || ua.includes('win32') || ua.includes('win64')) return 'windows';
      return 'mac';
    }

    const os = detectOS();

    function applyOsToButtons(macClass: string, winClass: string) {
      const macBtns = document.querySelectorAll<HTMLElement>(`.${macClass}`);
      const winBtns = document.querySelectorAll<HTMLElement>(`.${winClass}`);
      const hide = (btn: HTMLElement) => { (btn.parentElement ?? btn).style.display = 'none'; };
      if (os === 'mac') {
        winBtns.forEach(hide);
      } else {
        macBtns.forEach(hide);
      }
    }

    applyOsToButtons('hero-btn-mac', 'hero-btn-win');
    applyOsToButtons('cta-btn-mac', 'cta-btn-win');
  </script>
</Layout>
