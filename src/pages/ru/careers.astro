---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Карьера в Siplinx AI — Присоединяйтесь к команде',
  description: 'Присоединяйтесь к Siplinx AI и помогите создать будущее приватного локального AI для встреч. 20 открытых вакансий в разработке, дизайне и других направлениях.',
};

const jobs = [
  {
    title: 'Senior Rust Engineer',
    department: 'Разработка',
    type: 'Полная занятость · Удалённо',
    description: 'Разрабатывайте основной движок десктопного приложения для локального AI-инференса на macOS и Windows. Отвечайте за производительность STT и LLM пайплайнов.',
    tags: ['Rust', 'Системное ПО', 'macOS', 'Windows'],
  },
  {
    title: 'ML Engineer — On-Device LLM',
    department: 'AI / ML',
    type: 'Полная занятость · Удалённо',
    description: 'Оптимизируйте и дообучайте локальные языковые модели для суммаризации встреч. Работайте с квантизированными моделями (GGUF, MLX, ONNX) для достижения целевой задержки на потребительском железе.',
    tags: ['LLM', 'Python', 'GGUF', 'MLX'],
  },
  {
    title: 'Speech Recognition Engineer (STT)',
    department: 'AI / ML',
    type: 'Полная занятость · Удалённо',
    description: 'Улучшайте точность транскрипции и стриминг в реальном времени с локальными Whisper-моделями. Работайте над диаризацией спикеров, шумоподавлением и поддержкой нескольких языков.',
    tags: ['Whisper', 'ASR', 'Python', 'C++'],
  },
  {
    title: 'macOS Engineer (Swift / Objective-C)',
    department: 'Разработка',
    type: 'Полная занятость · Удалённо',
    description: 'Создавайте нативный UX для macOS — захват аудио, интерфейс в строке меню, системные разрешения и глубокую интеграцию с локальным AI-пайплайном.',
    tags: ['Swift', 'macOS', 'CoreAudio', 'AppKit'],
  },
  {
    title: 'Windows Engineer (C++ / C#)',
    department: 'Разработка',
    type: 'Полная занятость · Удалённо',
    description: 'Владейте Windows-клиентом. Разрабатывайте захват аудио, установщик и производительную интеграцию с локальными ML-моделями.',
    tags: ['C++', 'C#', 'Windows', 'WinRT'],
  },
  {
    title: 'Full-Stack Engineer (TypeScript / Node)',
    department: 'Разработка',
    type: 'Полная занятость · Удалённо',
    description: 'Разрабатывайте веб-дашборд, бэкенд лицензирования и функции синхронизации. Работайте над управлением аккаунтами, потоками подписок и экспортными интеграциями.',
    tags: ['TypeScript', 'Node.js', 'React', 'PostgreSQL'],
  },
  {
    title: 'Frontend Engineer (React / Astro)',
    department: 'Разработка',
    type: 'Полная занятость · Удалённо',
    description: 'Отвечайте за маркетинговый сайт и веб-вьюхи внутри приложения. Создавайте лендинги, потоки оплаты и просмотрщик заметок с фокусом на производительность и доступность.',
    tags: ['React', 'Astro', 'TypeScript', 'Tailwind'],
  },
  {
    title: 'DevOps / Platform Engineer',
    department: 'Разработка',
    type: 'Полная занятость · Удалённо',
    description: 'Создавайте CI/CD пайплайны, инфраструктуру автообновлений и подписывание кода для десктопных релизов. Обеспечивайте деплой без простоев для бэкенд-сервисов.',
    tags: ['GitHub Actions', 'Docker', 'Terraform', 'AWS'],
  },
  {
    title: 'Product Manager',
    department: 'Продукт',
    type: 'Полная занятость · Удалённо',
    description: 'Определяйте роадмап Siplinx AI — от базовых функций транскрипции до интеграций. Работайте в связке с пользователями, инженерами и дизайнерами.',
    tags: ['Роадмап', 'B2B', 'SaaS', 'Десктоп'],
  },
  {
    title: 'UX / Product Designer',
    department: 'Дизайн',
    type: 'Полная занятость · Удалённо',
    description: 'Проектируйте end-to-end опыт — от онбординга и установки моделей до панели заметок в реальном времени. Privacy-first, минималистично и с удовольствием.',
    tags: ['Figma', 'UX Research', 'Прототипирование', 'Design Systems'],
  },
  {
    title: 'Brand & Visual Designer',
    department: 'Дизайн',
    type: 'Полная занятость · Удалённо',
    description: 'Формируйте визуальную идентичность Siplinx AI — маркетинговые материалы, лендинги, графика для соцсетей и иллюстрации. Владейте брендом во всех точках контакта.',
    tags: ['Figma', 'Иллюстрация', 'Моушн', 'Брендинг'],
  },
  {
    title: 'Head of Growth',
    department: 'Маркетинг',
    type: 'Полная занятость · Удалённо',
    description: 'Руководите привлечением, удержанием и виральными механиками для privacy-first AI продукта. Запускайте эксперименты в SEO, платных каналах и сообществах.',
    tags: ['Growth', 'SEO', 'Paid', 'Аналитика'],
  },
  {
    title: 'Content Marketer / SEO',
    department: 'Маркетинг',
    type: 'Полная занятость · Удалённо',
    description: 'Пишите ценные статьи об AI, приватности, продуктивности на встречах и локальных AI-технологиях. Стройте органический трафик через экспертный контент и сравнения.',
    tags: ['SEO', 'Контент-стратегия', 'Копирайтинг', 'AI'],
  },
  {
    title: 'Developer Advocate',
    department: 'Маркетинг',
    type: 'Полная занятость · Удалённо',
    description: 'Выстраивайте отношения с разработчиками и техническими пользователями, которым важен локальный AI. Создавайте туториалы, демо и open-source интеграции.',
    tags: ['DevRel', 'Open Source', 'Сообщество', 'Техрайтинг'],
  },
  {
    title: 'Customer Success Manager',
    department: 'Поддержка клиентов',
    type: 'Полная занятость · Удалённо',
    description: 'Онбордите enterprise-клиентов, проводите бизнес-ревью и убеждайтесь, что команды получают максимум от Siplinx AI. Будьте мостом между пользователями и продуктом.',
    tags: ['Enterprise', 'B2B', 'Онбординг', 'Удержание'],
  },
  {
    title: 'Technical Support Engineer',
    department: 'Поддержка клиентов',
    type: 'Полная занятость · Удалённо',
    description: 'Помогайте пользователям решать проблемы с установкой, настройкой моделей и аудио. Создавайте документацию для самообслуживания и диагностические инструменты.',
    tags: ['Поддержка', 'macOS', 'Windows', 'Документация'],
  },
  {
    title: 'Enterprise Sales Executive',
    department: 'Продажи',
    type: 'Полная занятость · Удалённо',
    description: 'Закрывайте корпоративные сделки с юридическими, финансовыми и медицинскими командами. Ведите полный цикл — от первого звонка до подписанного контракта.',
    tags: ['Enterprise', 'B2B Продажи', 'SaaS', 'Юридика / Финансы'],
  },
  {
    title: 'Partnerships & BD Manager',
    department: 'Продажи',
    type: 'Полная занятость · Удалённо',
    description: 'Стройте стратегические партнёрства с privacy-focused организациями, реселлерами и экосистемами платформ. Развивайте интеграции с productivity-инструментами и CRM.',
    tags: ['Партнёрства', 'Интеграции', 'SaaS', 'BD'],
  },
  {
    title: 'Data Privacy & Compliance Lead',
    department: 'Юридика и комплаенс',
    type: 'Полная занятость · Удалённо',
    description: 'Управляйте программами GDPR, HIPAA и SOC 2. Консультируйте продукт и инженерию по privacy-by-design. Siplinx AI строится на локальной обработке — помогите нам это доказать.',
    tags: ['GDPR', 'HIPAA', 'SOC 2', 'Приватность'],
  },
  {
    title: 'AI Safety & Quality Researcher',
    department: 'AI / ML',
    type: 'Полная занятость · Удалённо',
    description: 'Оценивайте и red-team-ите выводы локальных AI-моделей на точность, галлюцинации и предвзятость. Определяйте бенчмарки качества для суммаризации встреч и извлечения задач.',
    tags: ['AI Safety', 'Оценка', 'Исследования', 'NLP'],
  },
];

const departments = [...new Set(jobs.map((j) => j.department))];
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
    >
    </div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-4">Мы нанимаем</p>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-gray-900 dark:text-white mb-6">
        Создавайте будущее<br />
        <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent"
          >приватного AI</span
        >
      </h1>
      <p class="text-xl text-gray-600 dark:text-slate-300 max-w-2xl mx-auto mb-10">
        В Siplinx AI мы верим: AI должен работать для вас — на вашем устройстве, под вашим контролем. Присоединяйтесь
        к небольшой амбициозной команде, которая создаёт AI для встреч без передачи данных.
      </p>
      <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-600 dark:text-slate-400">
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>
          100% Удалённо
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-blue-500 inline-block"></span>
          20 открытых вакансий
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-violet-500 inline-block"></span>
          Privacy-first культура
        </span>
      </div>
    </div>
  </section>

  <!-- Values strip -->
  <section class="bg-white dark:bg-[#060512] border-y border-gray-100 dark:border-slate-800 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      {
        [
          {
            icon: '🔒',
            title: 'Приватность по умолчанию',
            desc: 'Всё, что мы создаём, начинается с принципа: ваши данные принадлежат вам. Это не функция — это ценность.',
          },
          {
            icon: '⚡',
            title: 'Local-first инжиниринг',
            desc: 'Мы запускаем LLM и STT модели на вашем устройстве. Наши инженерные задачи — реальные: задержка, точность, энергопотребление и размер.',
          },
          {
            icon: '🌍',
            title: 'Async и удалённо',
            desc: 'Мы нанимаем лучших людей вне зависимости от местоположения. Мы общаемся письменно, двигаемся быстро и уважаем глубокую работу.',
          },
        ].map((v) => (
          <div class="px-4">
            <div class="text-4xl mb-3">{v.icon}</div>
            <h3 class="font-bold text-gray-900 dark:text-white mb-2">{v.title}</h3>
            <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">{v.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Job listings -->
  <section class="py-20 max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Открытые вакансии</h2>

    {
      departments.map((dept) => (
        <div class="mb-14">
          <h3 class="text-xs font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-4 pb-2 border-b border-gray-100 dark:border-slate-800">
            {dept}
          </h3>
          <div class="space-y-4">
            {jobs
              .filter((j) => j.department === dept)
              .map((job) => (
                <div class="group bg-white dark:bg-slate-900/50 border border-gray-100 dark:border-slate-800 rounded-xl p-6 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-md transition-all duration-200">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                    <div class="flex-1">
                      <h4 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                        {job.title}
                      </h4>
                      <p class="text-sm text-gray-500 dark:text-slate-400 mt-0.5 mb-3">{job.type}</p>
                      <p class="text-gray-600 dark:text-slate-300 text-sm leading-relaxed">{job.description}</p>
                      <div class="flex flex-wrap gap-2 mt-4">
                        {job.tags.map((tag) => (
                          <span class="px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                    <div class="flex-shrink-0">
                      <a
                        href={`mailto:careers@siplinx.com?subject=Отклик: ${encodeURIComponent(job.title)}`}
                        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-gradient-to-r from-blue-600 to-violet-600 text-white text-sm font-semibold hover:from-blue-700 hover:to-violet-700 transition-all"
                      >
                        Откликнуться
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              ))}
          </div>
        </div>
      ))
    }
  </section>

  <!-- CTA -->
  <section
    class="relative py-20 overflow-hidden bg-gradient-to-br from-blue-600 via-blue-700 to-violet-700 dark:from-blue-900 dark:via-blue-950 dark:to-violet-950"
  >
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-4xl font-bold text-white mb-4">Не нашли подходящую роль?</h2>
      <p class="text-xl text-blue-100 mb-8">
        Мы всегда ищем исключительных людей. Если вы верите в локальный AI и privacy-first технологии — напишите нам
        и расскажите, что бы вы построили.
      </p>
      <a
        href="mailto:careers@siplinx.com"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white text-blue-700 font-bold text-lg hover:bg-blue-50 transition-colors shadow-lg"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        careers@siplinx.com
      </a>
    </div>
  </section>
</Layout>
