---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget -->

  <HeroText
    tagline="Pricing"
    title="Simple, Honest Pricing"
    subtitle="Start free, upgrade when you're ready. No hidden fees, no surprises — just powerful local AI meeting notes."
  />

  <!-- Pricing Widget -->

  <Prices
    title="Plans for every meeting style"
    subtitle="All plans include 100% local processing — your data never leaves your device."
    prices={[
      {
        title: 'free',
        subtitle: 'Perfect for getting started',
        price: 0,
        period: 'per month',
        items: [
          {
            description: '10 meetings per month',
          },
          {
            description: 'Full AI transcription',
          },
          {
            description: 'Smart meeting summaries',
          },
          {
            description: 'Action item extraction',
          },
          {
            description: 'Export to Markdown & PDF',
          },
        ],
        callToAction: {
          text: 'Download Free',
          href: '/download',
        },
      },
      {
        title: 'pro',
        subtitle: 'For power users and professionals',
        price: 15,
        period: 'per month',
        items: [
          {
            description: 'Unlimited meetings',
          },
          {
            description: 'Everything in Free',
          },
          {
            description: 'Speaker identification',
          },
          {
            description: 'Custom vocabulary & names',
          },
          {
            description: 'Notion, Obsidian & Slack export',
          },
          {
            description: 'Priority model updates',
          },
        ],
        callToAction: {
          text: 'Get Pro',
          href: '/download',
        },
        hasRibbon: true,
        ribbonTitle: 'popular',
      },
      {
        title: 'team',
        subtitle: 'For growing teams',
        price: 49,
        period: 'per month',
        items: [
          {
            description: 'Up to 10 team members',
          },
          {
            description: 'Everything in Pro',
          },
          {
            description: 'Shared meeting library',
          },
          {
            description: 'Team action item tracking',
          },
          {
            description: 'Admin & user management',
          },
          {
            description: 'Priority support',
          },
        ],
        callToAction: {
          text: 'Get Team',
          href: '/download',
        },
      },
    ]}
  />

  <!-- Features3 Widget -->

  <Features3
    title="Every plan includes"
    subtitle="Core privacy and AI features available across all SipLinxAI plans"
    columns={2}
    items={[
      {
        title: '100% Local Processing',
        description: 'All AI transcription and summarization runs on your device. Zero cloud dependency, zero data exposure.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Works Offline',
        description: 'No internet required for transcription. SipLinxAI works anywhere, anytime — even on a plane.',
        icon: 'tabler:wifi-off',
      },
      {
        title: 'Multi-Platform Support',
        description: 'Zoom, Google Meet, Teams, Webex, Slack Huddles — works with every platform you already use.',
        icon: 'tabler:apps',
      },
      {
        title: 'Real-time Transcription',
        description: 'See your meeting transcript build in real time as the conversation unfolds.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Automatic Updates',
        description: 'Receive free model upgrades and new features automatically as we release them.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Mac & Windows',
        description: 'Native apps for macOS (Apple Silicon + Intel) and Windows 10/11. Fast, smooth, no Electron bloat.',
        icon: 'tabler:device-laptop',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget -->

  <Steps
    title="Get started in minutes"
    tagline="quick setup"
    isReversed={true}
    items={[
      {
        title: 'Download SipLinxAI',
        icon: 'tabler:number-1',
      },
      {
        title: 'Install (no account needed)',
        icon: 'tabler:number-2',
      },
      {
        title: 'Join any meeting',
        icon: 'tabler:number-3',
      },
      {
        title: 'Get your notes instantly',
        icon: 'tabler:number-4',
      },
      {
        title: 'Upgrade when you need more',
        icon: 'tabler:number-5',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'SipLinxAI setup steps',
    }}
  />

  <!-- FAQs Widget -->

  <FAQs
    title="Pricing FAQs"
    subtitle="Have questions about our plans? We've got answers."
    columns={1}
    items={[
      {
        title: 'Is the free plan really free forever?',
        description:
          'Yes. The free plan includes 10 meetings per month with no time limit and no credit card required. It stays free as long as you use SipLinxAI.',
      },
      {
        title: 'Can I upgrade or downgrade at any time?',
        description:
          'Absolutely. You can upgrade to Pro or Team at any time, or downgrade back to Free. Changes take effect at the start of your next billing cycle.',
      },
      {
        title: 'What counts as a "meeting"?',
        description:
          'Any transcription session counts as one meeting, regardless of length. A 10-minute standup and a 2-hour strategy session each count as one meeting.',
      },
      {
        title: 'What payment methods do you accept?',
        description:
          'We accept all major credit cards (Visa, Mastercard, Amex) and PayPal. All payments are processed securely through Stripe.',
      },
      {
        title: 'Is there an annual discount?',
        description:
          'Yes! Pay annually and save 20%. Pro becomes $12/mo and Team becomes $39/mo when billed yearly.',
      },
    ]}
  />

  <!-- CallToAction Widget -->

  <CallToAction
    title="Start your first AI meeting free"
    subtitle="No credit card. No cloud. No compromise on privacy."
    actions={[
      {
        variant: 'primary',
        text: 'Download Free',
        href: '/download',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
