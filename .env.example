# Siplinx AI — переменные окружения
# Скопируй этот файл в .env.local и заполни реальными значениями

# Cloudflare Pages
CF_API_TOKEN=
CF_ACCOUNT_ID=

# Аналитика (опционально)
PUBLIC_GOOGLE_ANALYTICS_ID=

# SE Ranking API (для выгрузки ключевых слов)
SE_RANKING_API_KEY=

# Сайт
PUBLIC_SITE_URL=https://siplinxai.com
